#!/bin/sh
# Skip if this commit is itself a version bump to prevent infinite loops
if git log -1 --pretty=%B | grep -qF "[version-bump]"; then
  exit 0
fi

COMMIT_MSG=$(git log -1 --pretty=%B)

# Suggest bump type based on conventional commit prefix
# feat! or BREAKING CHANGE → major; feat → minor; fix → patch; everything else → skip
if echo "$COMMIT_MSG" | grep -qE "^BREAKING CHANGE:" || \
   echo "$COMMIT_MSG" | grep -qiE "^feat(\(.+\))?!:"; then
  SUGGESTED="major"
elif echo "$COMMIT_MSG" | grep -qiE "^feat(\(.+\))?:"; then
  SUGGESTED="minor"
elif echo "$COMMIT_MSG" | grep -qiE "^fix(\(.+\))?:"; then
  SUGGESTED="patch"
else
  SUGGESTED="skip"
fi

# Skip prompt in non-interactive environments (CI, automated tools)
if ! { : < /dev/tty; } 2>/dev/null; then
  exit 0
fi
exec < /dev/tty

printf "\nSuggested bump: %s (%s)\n" "$SUGGESTED" "$(echo "$COMMIT_MSG" | head -1)"
printf "Accept [Enter], or choose: [p]atch / [m]inor / [M]ajor / [s]kip: "
read -r answer

case "$answer" in
  "")
    TYPE="$SUGGESTED" ;;
  p|patch)
    TYPE="patch" ;;
  m|minor)
    TYPE="minor" ;;
  M|major)
    TYPE="major" ;;
  *)
    TYPE="skip" ;;
esac

if [ "$TYPE" = "skip" ]; then
  echo "Skipping version bump."
  exit 0
fi

if ! npm version "$TYPE" --no-git-tag-version --silent; then
  echo "Version bump failed — package.json was not modified." >&2
  exit 1
fi

NEW_VERSION=$(node -p "require('./package.json').version")
git add package.json package-lock.json
git commit -m "chore: bump version to $NEW_VERSION [version-bump]"
echo "Version bumped to $NEW_VERSION"
